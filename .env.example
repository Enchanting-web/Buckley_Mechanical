# Appwrite project configuration
# Copy this file to .env.local and fill in your values

# Your Appwrite API endpoint (default: https://cloud.appwrite.io/v1)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID (found in Appwrite Console → Settings)
VITE_APPWRITE_PROJECT_ID=

# (Optional) Appwrite Database ID for contact-form submissions
VITE_APPWRITE_DATABASE_ID=

# (Optional) Appwrite Collection ID for contact-form submissions
VITE_APPWRITE_COLLECTION_ID=
